# ---------------------------------------------------------------------------
# Bennet Legal Research Group — environment variables
# Copy to `.env` (local) or create `.env` on the server. NEVER commit real values.
# ---------------------------------------------------------------------------

# Public site URL (used for canonical URLs, sitemap, Open Graph).
NEXT_PUBLIC_SITE_URL=https://bennetlegalpartners.com

# --- AWS SES (contact / proposal form email) ---
# Region where your SES identities live.
AWS_REGION=us-east-1
# Least-privilege IAM user with ses:SendEmail / ses:SendRawEmail only.
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# A VERIFIED SES sender identity (email or a verified domain address).
CONTACT_FROM_EMAIL=intelligence@bennetlegalpartners.com
# Where contact submissions are delivered.
CONTACT_TO_EMAIL=you@yourdomain.com

# --- Stripe (mock by default) ---
# Leave STRIPE_SECRET_KEY unset to keep checkout in safe "mock mode".
# STRIPE_SECRET_KEY=sk_live_or_test_...
# STRIPE_PRICE_ID=price_...
